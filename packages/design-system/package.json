{
  "name": "@secureloop/design-system",
  "version": "0.1.0",
  "description": "SecureLoop Design System — tokens, themes, motion, elevation, data-viz",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./css": "./dist/global.css",
    "./tokens": {
      "types": "./dist/tokens/index.d.ts",
      "import": "./dist/tokens/index.js"
    },
    "./themes": {
      "types": "./dist/themes/index.d.ts",
      "import": "./dist/themes/index.js"
    }
  },
  "files": ["dist", "src"],
  "sideEffects": ["*.css", "./src/global/**"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18.0.0"
  },
  "dependencies": {
    "@vanilla-extract/css": "^1.15.0",
    "@vanilla-extract/dynamic": "^2.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vanilla-extract/esbuild-plugin": "^2.3.0",
    "@vanilla-extract/vite-plugin": "^4.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  }
}