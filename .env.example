# SecureLoop — local dev environment
# Copy to .env and adjust per local setup. .env is gitignored.

# ─── Postgres ───────────────────────────────────────────────────────────────
POSTGRES_USER=secureloop
POSTGRES_PASSWORD=secureloop_dev
POSTGRES_DB=secureloop
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://secureloop:secureloop_dev@localhost:5432/secureloop

# Per-service databases (created by infra/scripts/postgres-init.sql)
DATABASE_URL_AUTH=postgresql://secureloop:secureloop_dev@localhost:5432/secureloop_auth
DATABASE_URL_TENANTS=postgresql://secureloop:secureloop_dev@localhost:5432/secureloop_tenants
DATABASE_URL_USERS=postgresql://secureloop:secureloop_dev@localhost:5432/secureloop_users
DATABASE_URL_ENGAGEMENTS=postgresql://secureloop:secureloop_dev@localhost:5432/secureloop_engagements
DATABASE_URL_FINDINGS=postgresql://secureloop:secureloop_dev@localhost:5432/secureloop_findings

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_PASSWORD=secureloop_dev
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://:secureloop_dev@localhost:6379

# ─── RabbitMQ ───────────────────────────────────────────────────────────────
RABBITMQ_USER=secureloop
RABBITMQ_PASSWORD=secureloop_dev
RABBITMQ_VHOST=/
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
RABBITMQ_URL=amqp://secureloop:secureloop_dev@localhost:5672

# ─── Elasticsearch ──────────────────────────────────────────────────────────
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_URL=http://localhost:9200

# ─── MinIO (S3-compatible object store) ─────────────────────────────────────
MINIO_ROOT_USER=secureloop
MINIO_ROOT_PASSWORD=secureloop_dev
MINIO_ENDPOINT=http://localhost:9000
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# ─── MailHog (dev email capture) ────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025

# ─── App config ─────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug

# JWT signing secret — generate per env: `openssl rand -base64 48`
JWT_SECRET=change-me-locally-please-generate-with-openssl-rand-base64-48
JWT_ISSUER=secureloop-dev
JWT_AUDIENCE=secureloop-dev

# AI Gateway (Anthropic) — leave blank locally unless testing AI flows
ANTHROPIC_API_KEY=
AI_GATEWAY_URL=http://localhost:4100

# ─── Service URLs (consumed by apps via NEXT_PUBLIC_* prefix) ─────────────────
SERVICE_AUTH_URL=http://localhost:4000
SERVICE_TENANTS_URL=http://localhost:4001
SERVICE_FINDINGS_URL=http://localhost:4002
SERVICE_ENGAGEMENTS_URL=http://localhost:4003

# Browser-side: Next.js exposes only NEXT_PUBLIC_* env to the client.
NEXT_PUBLIC_SERVICE_AUTH_URL=http://localhost:4000
NEXT_PUBLIC_SERVICE_TENANTS_URL=http://localhost:4001
