{
  "name": "secureloop",
  "version": "0.1.0",
  "private": true,
  "description": "SecureLoop GRC Platform · monorepo",
  "packageManager": "pnpm@9.0.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*",
    "services/*"
  ],
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm -r --parallel run dev",
    "typecheck": "pnpm -r run typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm -r --if-present run test",
    "clean": "pnpm -r exec rm -rf dist node_modules",
    "stack:up": "docker compose up -d",
    "stack:down": "docker compose down",
    "stack:logs": "docker compose logs -f",
    "stack:ps": "docker compose ps",
    "stack:reset": "bash infra/scripts/reset.sh",
    "stack:setup": "bash infra/scripts/dev-setup.sh",
    "db:migrate": "pnpm -r --if-present run db:migrate",
    "db:seed": "tsx infra/scripts/seed.ts"
  },
  "devDependencies": {
    "@node-rs/argon2": "^2.0.2",
    "@secureloop/db": "workspace:*",
    "@secureloop/eslint-config": "workspace:*",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.2",
    "eslint": "^9.13.0",
    "postgres": "^3.4.5",
    "prettier": "^3.3.3",
    "tsx": "^4.19.2",
    "typescript": "^5.5.0"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "0.25.12",
      "fastify": "4.28.1"
    }
  }
}
