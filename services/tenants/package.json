{
  "name": "@secureloop/service-tenants",
  "version": "0.1.0",
  "private": true,
  "description": "Tenant provisioning, config, and framework toggles",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate-cli.ts"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.0",
    "@secureloop/auth-client": "workspace:*",
    "@secureloop/db": "workspace:*",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "postgres": "^3.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "drizzle-kit": "^0.28.1",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.5.0"
  }
}
